{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>elastic/renovate-config"
  ],
  "schedule": [
    "after 1am on monday"
  ],
  "packageRules": [
    {
      "description": "rmcp 1.x needs a code migration; stay on 0.2 for now",
      "matchDatasources": ["crate"],
      "matchPackageNames": ["rmcp", "rmcp-macros"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
